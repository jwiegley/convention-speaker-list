{
  "name": "@convention/backend",
  "version": "1.0.0",
  "description": "Backend API server for Convention Speaker List Manager",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "TS_NODE_TRANSPILE_ONLY=true TS_NODE_PROJECT=tsconfig.json nodemon",
    "build": "npx --package=typescript tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "clean": "rm -rf dist",
    "db:create": "ts-node src/database/createDb.ts",
    "db:migrate": "ts-node src/database/migrate.ts",
    "db:migrate:down": "ts-node src/database/migrate.ts down",
    "db:migrate:create": "node-pg-migrate create --migration-file-language ts --template-file-name src/database/migration-template.ts",
    "db:seed": "ts-node src/database/seed.ts",
    "db:seed:auth": "ts-node src/database/seedAuth.ts",
    "db:reset": "npm run db:migrate:down -- --count=1000 && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-pg-migrate": "^8.0.3",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "socket.io-redis": "^5.4.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/socket.io": "^3.0.1",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "api",
    "express",
    "typescript",
    "websocket"
  ],
  "author": "",
  "license": "MIT"
}
