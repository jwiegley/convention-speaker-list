# Backend Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://convention_user:convention_pass@localhost:5432/convention_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=convention_db
DATABASE_USER=convention_user
DATABASE_PASSWORD=convention_pass

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
SOCKET_IO_CORS_ORIGIN=http://localhost:5173

# Security Configuration
JWT_SECRET=your-secret-jwt-key-change-in-production
SESSION_SECRET=your-secret-session-key-change-in-production
DEFAULT_ADMIN_PIN=1234
ENCRYPTION_MASTER_KEY=your-encryption-master-key-change-in-production
ENCRYPTION_SALT=your-encryption-salt-change-in-production

# HTTPS/SSL Configuration
HTTPS_ENABLED=false
HTTPS_PORT=3443
REDIRECT_HTTP=false
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key
SSL_CA_PATH=./certs/ca.crt

# For development only - generates self-signed certificates
GENERATE_SELF_SIGNED=false

# Force HTTPS in development
FORCE_HTTPS=false

# Initial Authentication Passwords (optional)
# If not set, random passwords will be generated
INITIAL_ADMIN_PASSWORD=
INITIAL_SPECTATOR_PASSWORD=

# Logging Configuration
LOG_LEVEL=info

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_MAX_AGE=86400000
SESSION_TIMEOUT_MS=900000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@convention-speaker-list.com

# Monitoring Configuration
ENABLE_MONITORING=true
METRICS_PORT=9090

# External Services
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# Feature Flags
ENABLE_WEBSOCKET_SCALING=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_DATA_ENCRYPTION=true

# Performance Configuration
MAX_POOL_SIZE=20
CONNECTION_TIMEOUT_MS=5000
STATEMENT_TIMEOUT_MS=30000

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups